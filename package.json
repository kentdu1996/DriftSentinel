{
  "name": "driftsentinel",
  "version": "0.1.0",
  "private": true,
  "description": "AI service degradation detection + decentralized public-verdict network",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "db:init": "pnpm --filter @driftsentinel/core db:init",
    "driftsentinel": "tsx packages/cli/src/cli.ts",
    "probe:once": "tsx packages/probe/src/cli.ts",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
